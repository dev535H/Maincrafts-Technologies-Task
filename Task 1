---------------------------------------------------
-- TASK QUERIES
---------------------------------------------------

-- 1 Average Math Score
SELECT AVG(MathScore) AS AvgMath
FROM Students;

-- 2 Highest Science Score
SELECT MAX(ScienceScore) AS HighestScience
FROM Students;

-- 3 Count Students
SELECT COUNT(*) AS TotalStudents
FROM Students;

-- 4 Students Scoring Above 90 in Math
SELECT *
FROM Students
WHERE MathScore > 90;

-- 5 Average Score by Grade
SELECT Grade,
AVG(MathScore) AS AvgMath
FROM Students
GROUP BY Grade;

-- 6 Female Students
SELECT *
FROM Students
WHERE Gender='F';

-- 7 Students Age > 15
SELECT *
FROM Students
WHERE Age>15;

-- 8 Top Performer
SELECT Name,
(MathScore+ScienceScore+EnglishScore) AS Total
FROM Students
ORDER BY Total DESC
LIMIT 1;

-- 9 Overall Average Marks
SELECT Name,
ROUND(
(MathScore+ScienceScore+EnglishScore)/3.0,
2
) AS AverageMarks
FROM Students;

-- 10 Update Grade
UPDATE Students
SET Grade='A+'
WHERE StudentID=1;

-- Check Final Data
SELECT * FROM Students;
