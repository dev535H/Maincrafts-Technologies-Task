-- Create Database

CREATE DATABASE Student_Management;
-- Connect Database
\c Student_Management;

-- Create Table
CREATE TABLE Students (
    StudentID SERIAL PRIMARY KEY,
    Name VARCHAR(50),
    Gender CHAR(1),
    Age INT,
    Grade VARCHAR(2),
    MathScore INT,
    ScienceScore INT,
    EnglishScore INT
);

